{
  "name": "spotify-kit",
  "version": "2.1.0",
  "description": "Minimal utility to fetch the user's currently playing Spotify track via the Web API.",
  "license": "MIT",
  "author": "Biki Mandal",
  "repository": {
    "type": "git",
    "url": "https://github.com/bikimandal/spotify-kit.git"
  },
  "keywords": [
    "spotify-kit",
    "spotify",
    "now-playing",
    "currently-playing",
    "web-api",
    "music"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "bin": {
    "spotify-kit-login": "./dist/cli-login.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "login": "npm run build && node dist/cli-login.js",
    "test:live": "npm run build && node examples/live-now-playing.mjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
